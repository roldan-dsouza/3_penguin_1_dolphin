{
  "manifest_version": 3,
  "name": "ReadEase",
  "version": "1.0",
  "description": "Makes web content easier for dyslexic readers",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": ["http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
